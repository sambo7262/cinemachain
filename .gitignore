# Secrets — never commit
.env
.env.local
.env.*.local

# Docker volume data — stored on NAS, not in repo
# Subdirectory contents excluded; .gitkeep files committed to track directory structure
volumes/*/*
!volumes/*/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/

# IDE
.idea/
.vscode/
*.swp
*.swo

# macOS
.DS_Store
