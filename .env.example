# CinemaChain — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# --- Database ---
# Password for the PostgreSQL cinemachain user
DB_PASSWORD=changeme

# --- Synology NAS User IDs ---
# Get these by running: id your_docker_username
# on your NAS via SSH. Must match the user running Docker.
PUID=1000
PGID=1000

# --- Tailscale ---
# Generate at: https://login.tailscale.com/admin/settings/keys
# Use a reusable, pre-authorized key tagged "tag:server" to avoid
# re-authentication after container recreation.
TS_AUTHKEY=tskey-auth-xxxxx

# --- TMDB ---
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# --- Plex ---
# Token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=
# URL of your Plex server (LAN IP, not Plex.tv)
PLEX_URL=http://192.168.x.x:32400

# --- Radarr ---
RADARR_URL=http://192.168.x.x:7878
RADARR_API_KEY=

# --- Sonarr ---
SONARR_URL=http://192.168.x.x:8989
SONARR_API_KEY=
