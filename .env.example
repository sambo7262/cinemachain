# CinemaChain — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# --- Database ---
# Password for the PostgreSQL cinemachain user
DB_PASSWORD=changeme

# --- Synology NAS User IDs ---
# Get these by running: id your_docker_username
# on your NAS via SSH. Must match the user running Docker.
PUID=1031
PGID=65536

# --- TMDB ---
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=522b85ebeae0099a31b0afa55bfafb0a

# --- Plex ---
# Token: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=-iD1FozfudrStt34ygfS
# URL of your Plex server (LAN IP, not Plex.tv)
PLEX_URL=http://192.168.86.37:32400

# --- Radarr ---
RADARR_URL=http://192.168.86.37:7878
RADARR_API_KEY=01ac4dd5cc3448fdb612cf259a4dcb0c

# --- Sonarr ---
SONARR_URL=http://192.168.86.37:8989
SONARR_API_KEY=316ff83614f44000b23248c5c9ce4e3a
