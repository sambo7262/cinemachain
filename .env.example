# CinemaChain — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.

# --- Database ---
# Password for the PostgreSQL cinemachain user — choose something strong
DB_PASSWORD=choose_a_strong_password

# --- Host paths ---
# Base directory for all Docker volume bind-mounts.
# Default ./data works on any host. Override for NAS, e.g.:
#   DATA_DIR=/volume1/docker/appdata/cinemachain
DATA_DIR=./data

# --- User/Group IDs ---
# Linux UID/GID for file ownership inside containers.
# Find yours with: id $(whoami)
# Default 1000 is the standard first Linux user.
PUID=1000
PGID=1000

# --- TMDB ---
# Get your API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# --- Radarr ---
# URL of your Radarr instance (LAN IP or hostname)
RADARR_URL=http://YOUR_HOST_IP:7878
# Radarr API key — Settings > General > Security > API Key
RADARR_API_KEY=your_radarr_api_key_here
# Quality profile name to assign when requesting movies (default: HD+)
RADARR_QUALITY_PROFILE=HD+

# --- TMDB Nightly Cache ---
# Time to run the nightly cache refresh (24h UTC format)
TMDB_CACHE_TIME=03:00
# Number of top-voted movies to pre-cache in the nightly run
TMDB_CACHE_TOP_N=5000
# Number of popular actors to pre-warm in the nightly run
TMDB_CACHE_TOP_ACTORS=1500
# Run cache refresh immediately on app startup (true/false)
# Useful for first deploy or testing; disable for production
TMDB_CACHE_RUN_ON_STARTUP=false

# --- Settings Encryption ---
# Auto-generated and persisted on first run — you do not need to set this.
# CinemaChain writes the key to data/.encryption_key on the Docker volume.
# Only set this manually if you want to use a specific key (e.g. for key rotation).
SETTINGS_ENCRYPTION_KEY=
