# Database
DATABASE_URL=postgresql+asyncpg://cinemachain:changeme@db:5433/cinemachain
DB_PASSWORD=changeme

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here

# Plex
PLEX_TOKEN=your_plex_token_here
PLEX_URL=http://your-plex-server:32400

# Radarr
RADARR_URL=http://your-radarr:7878
RADARR_API_KEY=your_radarr_api_key_here
RADARR_QUALITY_PROFILE=HD+

# Sonarr
SONARR_URL=http://your-sonarr:8989
SONARR_API_KEY=your_sonarr_api_key_here

# Tailscale
TS_AUTHKEY=your_tailscale_authkey_here

# Synology NAS — match host user/group IDs
PUID=1000
PGID=1000

# Settings encryption key (optional) — encrypt sensitive settings stored in DB
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# TMDB nightly cache — number of top-voted movies to pre-cache
TMDB_CACHE_TOP_N=5000
# TMDB nightly cache run time in 24h UTC format (HH:MM)
TMDB_CACHE_TIME=03:00
# Set to true to run the cache job immediately on startup (useful for first deploy / testing)
TMDB_CACHE_RUN_ON_STARTUP=false
