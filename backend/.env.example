# Database
DATABASE_URL=postgresql+asyncpg://cinemachain:changeme@db:5433/cinemachain
DB_PASSWORD=changeme

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here

# Radarr
RADARR_URL=http://your-radarr:7878
RADARR_API_KEY=your_radarr_api_key_here
RADARR_QUALITY_PROFILE=HD+

# Synology NAS — match host user/group IDs
PUID=1000
PGID=1000

# Settings encryption key — auto-generated and persisted on first run
# CinemaChain writes the key to data/.encryption_key on the Docker volume.
# Only set this manually if you want to use a specific key (e.g. for key rotation).
SETTINGS_ENCRYPTION_KEY=

# TMDB nightly cache — number of top-voted movies to pre-cache
TMDB_CACHE_TOP_N=5000
# TMDB nightly cache — number of top actors to pre-fetch filmographies
TMDB_CACHE_TOP_ACTORS=1500
# TMDB nightly cache run time in 24h format (Los Angeles time) (HH:MM)
TMDB_CACHE_TIME=03:00
# Set to true to run the cache job immediately on startup (useful for first deploy / testing)
TMDB_CACHE_RUN_ON_STARTUP=false
